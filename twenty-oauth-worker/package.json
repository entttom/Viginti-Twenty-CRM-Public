{
  "name": "viginti-twenty-oauth",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker for the OAuth login of the native iOS app 'Viginti – Twenty Client'. Supports a direct public PKCE client (Mode A) and a managed OAuth broker (Mode B). Never an open OAuth or HTTP proxy.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@eslint/js": "^9.10.0",
    "eslint": "^9.10.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.5.0",
    "vitest": "^2.1.1",
    "wrangler": "^4.103.0"
  }
}
